# =============================================================================
# Polymarket AI Trading Bot — environment template
# =============================================================================
# 1. Copy this file:           cp env.template .env
# 2. Fill in the values below.
# 3. .env is git-ignored (see .gitignore). NEVER commit your private key.
# =============================================================================


# -----------------------------------------------------------------------------
# Polymarket — Polygon wallet & CLOB
# -----------------------------------------------------------------------------
# REQUIRED. Private key of the Polygon wallet that will sign orders.
# - For an EOA (MetaMask / hardware wallet exported key): the key of the
#   wallet that holds USDC.e on Polygon.
# - For Magic Link / proxy wallets: the key of the SIGNER, not the proxy
#   address itself (proxy address goes in POLYMARKET_FUNDER below).
# Format: 0x-prefixed 64-hex-char string.
POLYMARKET_PRIVATE_KEY=0xyour_polygon_private_key_here

# OPTIONAL. Address that holds the USDC and receives positions. Required ONLY
# when SIGNATURE_TYPE != 0 (i.e. Magic Link / Gnosis Safe / proxy setups).
# For an EOA, leave this blank — funder defaults to the signer address.
POLYMARKET_FUNDER=

# Signature scheme used by the wallet:
#   0 = EOA / browser wallet (MetaMask, hardware wallet, exported key)
#   1 = Magic Link (Polymarket email-login proxy wallet)
#   2 = Gnosis Safe / browser proxy wallet
# Default: 0 (matches a private key exported from MetaMask).
POLYMARKET_SIGNATURE_TYPE=0

# CLOB API host. Production = https://clob.polymarket.com
POLYMARKET_HOST=https://clob.polymarket.com

# Chain ID. Polygon mainnet = 137. Polymarket has no separate testnet.
POLYMARKET_CHAIN_ID=137

# OPTIONAL. Polygon RPC endpoint used for USDC balance reads and allowance
# transactions. Defaults to https://polygon-rpc.com if unset (rate-limited
# public endpoint — supply your own Alchemy/QuickNode/Infura URL for live use).
POLYGON_RPC_URL=

# OPTIONAL. Override the Gamma API host used for market discovery.
# Default: https://gamma-api.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com


# -----------------------------------------------------------------------------
# LLM — OpenRouter (single key, all models)
# -----------------------------------------------------------------------------
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here


# -----------------------------------------------------------------------------
# Trading mode — DRY RUN BY DEFAULT
# -----------------------------------------------------------------------------
# DRY_RUN=true  → no orders are sent on-chain (paper mode, safe default)
# DRY_RUN=false → REAL orders against REAL USDC. Combine with caution.
#
# LIVE_TRADING_ENABLED is the legacy flag still read by parts of the codebase.
# It is the inverse of DRY_RUN. If both are set, DRY_RUN wins.
DRY_RUN=true
LIVE_TRADING_ENABLED=false


# -----------------------------------------------------------------------------
# Cost & safety limits
# -----------------------------------------------------------------------------
# Hard cap on daily LLM spend (USD). The bot halts trading until midnight UTC
# once the cap is hit. Default 10.
DAILY_AI_COST_LIMIT=10.0


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///trading_system.db


# -----------------------------------------------------------------------------
# Performance monitoring (internal telemetry, not third-party)
# -----------------------------------------------------------------------------
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL_MINUTES=15
